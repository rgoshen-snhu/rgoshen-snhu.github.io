source "https://rubygems.org"

# GitHub Pages bundle — Jekyll plus all officially-supported plugins and
# themes, version-locked to match what GitHub Pages runs in production.
gem "github-pages", group: :jekyll_plugins

# Platform-specific gems (no-op on macOS/Linux).
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
